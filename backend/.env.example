# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/zemeplocha

# JWT secret for custom tokens — min 32 chars
JWT_SECRET=change-me-to-a-random-32-char-secret

# Supabase JWT secret — required if frontend uses Supabase Auth
# Found in: Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Stripe (optional for dev)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS origin
FRONTEND_URL=http://localhost:5173

# Server port
PORT=4000
